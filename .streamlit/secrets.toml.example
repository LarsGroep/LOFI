# Copy this to .streamlit/secrets.toml for local dev,
# or paste each key into the Streamlit Cloud Secrets UI (Settings → Secrets).

ANTHROPIC_API_KEY = "sk-ant-..."

# Spotify (enricher + profile photos)
SPOTIFY_CLIENT_ID = ""
SPOTIFY_CLIENT_SECRET = ""

# Profile generation backend: "claude" (default) or "ollama" (local only)
PROFILE_BACKEND = "claude"

# Neo4j — used for persistent swipe storage across Streamlit Cloud restarts
# Get the bolt URI from your Aura console (e.g. neo4j+s://xxxxxxxx.databases.neo4j.io)
NEO4J_URI      = "neo4j+s://xxxxxxxx.databases.neo4j.io"
NEO4J_USER     = ""
NEO4J_PASSWORD = ""
