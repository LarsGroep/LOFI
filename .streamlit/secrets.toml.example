# Copy this to .streamlit/secrets.toml for local dev,
# or paste each key into the Streamlit Cloud Secrets UI (Settings → Secrets).

ANTHROPIC_API_KEY = "sk-ant-..."

# Spotify (enricher + profile photos)
SPOTIFY_CLIENT_ID = ""
SPOTIFY_CLIENT_SECRET = ""

# Profile generation backend: "claude" (default) or "ollama" (local only)
PROFILE_BACKEND = "claude"

# Supabase — persistent swipe storage + artist data across Streamlit Cloud restarts
# Find these in your Supabase project: Settings → API
SUPABASE_URL = "https://<project-id>.supabase.co"
SUPABASE_KEY = ""   # anon/publishable key

# Discogs
DISCOGS_KEY    = ""
DISCOGS_SECRET = ""

# YouTube Data API v3
YOUTUBE_API_KEY = ""

# Mixcloud
MIXCLOUD_CLIENT_ID     = ""
MIXCLOUD_CLIENT_SECRET = ""
