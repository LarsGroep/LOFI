# Paste these into Streamlit Cloud → Settings → Secrets, or copy to .streamlit/secrets.toml for local dev.

SUPABASE_URL = "https://<project-id>.supabase.co"
SUPABASE_KEY = ""   # anon/publishable key

CHARTMETRIC_REFRESH_TOKEN = ""   # required — from chartmetric.com dashboard (Account → API)

LASTFM_API_KEY = ""   # optional — used by the Last.fm scraper
