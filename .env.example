ANTHROPIC_API_KEY=sk-ant-...

# Supabase
SUPABASE_URL=https://<project-id>.supabase.co
SUPABASE_KEY=

# Spotify (for artist profile photos — optional)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Chartmetric (developer plan — use refresh token from chartmetric.com dashboard)
CHARTMETRIC_REFRESH_TOKEN=

# Profile generation backend: "claude" (default) or "ollama" (local, free)
PROFILE_BACKEND=claude
# OLLAMA_MODEL=llama3.2
# OLLAMA_BASE_URL=http://localhost:11434

# Scraper API keys (GitHub Actions uses these as secrets)
LASTFM_API_KEY=
DISCOGS_KEY=
DISCOGS_SECRET=
YOUTUBE_API_KEY=

# ── LOFI AI agent (scout/chat + validation) ──────────────────────────────────
# LLM layer. Only enable once Lofi's permission + retention are settled.
LOFI_LLM_ENABLED=          # 1 to turn Claude on (default off = preview mode)
LOFI_LLM_LANG=en           # en | nl  (the validation panel is always English)
# LOFI_LLM_MODEL=claude-opus-4-8
# LOFI_LLM_INFERENCE_GEO=us
# The validation panel uses Claude's managed web search (web_search_20260209).
# Enable web search ONCE in the Anthropic Console (org settings) or the call
# errors. Billing ~$10/1,000 searches; each validation uses <=4.

# Airtable (read-only) — booking history + per-artist economics for the AI.
# Defaults match LOFI's base: "Bookings / Line-up" + "Artists".
AIRTABLE_TOKEN=            # Airtable personal access token (data.records:read)
AIRTABLE_BASE_ID=          # app... (run: python -m scout.airtable  to discover)
# AIRTABLE_BOOKINGS_TABLE=Bookings / Line-up
# AIRTABLE_ARTISTS_TABLE=Artists
# Field-name overrides only if the schema changes — see scout/airtable.py (_BK/_AR).
# Verify the two-table join with: python -m scout.airtable verify
