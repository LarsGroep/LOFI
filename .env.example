ANTHROPIC_API_KEY=sk-ant-...

# Supabase
SUPABASE_URL=https://<project-id>.supabase.co
SUPABASE_KEY=

# Spotify (for artist profile photos — optional)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Chartmetric (developer plan — use refresh token from chartmetric.com dashboard)
CHARTMETRIC_REFRESH_TOKEN=

# Profile generation backend: "claude" (default) or "ollama" (local, free)
PROFILE_BACKEND=claude
# OLLAMA_MODEL=llama3.2
# OLLAMA_BASE_URL=http://localhost:11434

# Scraper API keys (GitHub Actions uses these as secrets)
LASTFM_API_KEY=
DISCOGS_KEY=
DISCOGS_SECRET=
YOUTUBE_API_KEY=
