ANTHROPIC_API_KEY=sk-ant-...

# Supabase
SUPABASE_URL=https://<project-id>.supabase.co
SUPABASE_KEY=

# Spotify (for artist profile photos — optional)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Chartmetric (developer plan — use refresh token from chartmetric.com dashboard)
CHARTMETRIC_REFRESH_TOKEN=

# Profile generation backend: "claude" (default) or "ollama" (local, free)
PROFILE_BACKEND=claude
# OLLAMA_MODEL=llama3.2
# OLLAMA_BASE_URL=http://localhost:11434

# Scraper API keys (GitHub Actions uses these as secrets)
LASTFM_API_KEY=
DISCOGS_KEY=
DISCOGS_SECRET=
YOUTUBE_API_KEY=

# ── LOFI AI agent (scout/chat) ───────────────────────────────────────────────
# LLM layer. Only enable once Lofi's permission + retention are settled.
LOFI_LLM_ENABLED=          # 1 to turn Claude on (default off = preview mode)
LOFI_LLM_LANG=en           # en | nl
# LOFI_LLM_MODEL=claude-opus-4-8
# LOFI_LLM_INFERENCE_GEO=us

# Airtable (read-only) — booking history + comparables for the AI
AIRTABLE_TOKEN=            # Airtable personal access token (data.records:read)
AIRTABLE_BASE_ID=          # app... (run: python -m scout.airtable  to discover)
AIRTABLE_BOOKINGS_TABLE=   # the table holding past bookings/events
# Field-name overrides (defaults: Artist/Fee/Date/Event/Venue/Genre/"Tickets sold").
# Set these after running the introspector if your columns differ:
# AIRTABLE_F_ARTIST=Artist
# AIRTABLE_F_GAGE=Fee
# AIRTABLE_F_DATE=Date
# AIRTABLE_F_EVENT=Event
# AIRTABLE_F_VENUE=Venue
# AIRTABLE_F_GENRE=Genre
# AIRTABLE_F_OUTCOME=Tickets sold
